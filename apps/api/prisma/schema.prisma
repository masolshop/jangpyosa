generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                String   @id @default(cuid())
  phone             String   @unique
  username          String?  @unique       // 🆕 기업 로그인 ID (영문+숫자)
  email             String?
  passwordHash      String
  name              String
  role              String                 // BUYER, SUPPLIER, AGENT, SUPER_ADMIN, EMPLOYEE
  branchId          String?
  refCode           String?  @unique
  referredById      String?
  
  // 🆕 기업 소속 정보 (ownerUserId 대신 companyId 사용)
  companyId         String?                // 소속 회사 ID
  isCompanyOwner    Boolean  @default(false) // 회사 최초 생성자 여부
  
  // 🆕 기업 담당자 정보 (SUPPLIER, BUYER 전용)
  managerName       String?                // 담당자 성함
  managerTitle      String?                // 담당자 직함
  managerEmail      String?                // 담당자 이메일
  managerPhone      String?                // 담당자 핸드폰 (알림톡용)
  
  // 🆕 직원 계정 전용 필드 (EMPLOYEE 역할)
  employeeId        String?  @unique       // DisabledEmployee ID (매칭용)
  companyBizNo      String?                // 소속 기업 사업자등록번호
  
  // 🆕 개인정보 동의
  privacyAgreed     Boolean  @default(false)
  privacyAgreedAt   DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  companyType       String?
  company           Company? @relation("CompanyMembers", fields: [companyId], references: [id])
  ownedCompany      Company? @relation("CompanyOwner") // ownerUserId 관계 유지
  referredBy        User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals         User[]   @relation("Referrals")
  branch            Branch?  @relation(fields: [branchId], references: [id])
  sentInvitations   TeamInvitation[] @relation("InvitationSender")
  notifications     Notification[] @relation("UserNotifications")
  
  @@index([companyId])
  @@index([isCompanyOwner])
}

model Branch {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  region    String?
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agents    User[]
}

model Company {
  id                String           @id @default(cuid())
  name              String
  bizNo             String           @unique
  representative    String?
  type              String
  buyerType         String?          // 🆕 BUYER 전용: PRIVATE_COMPANY, PUBLIC_INSTITUTION, GOVERNMENT
  isVerified        Boolean          @default(false)
  apickData         String?
  ownerUserId       String           @unique      // 🆕 기존 필드 유지 (호환성)
  attachmentEmail   String?          // 🆕 첨부파일 수신용 이메일 (휴가 증빙서류, 업무지시 파일 등)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  members           User[]           @relation("CompanyMembers") // 🆕 1:N 관계 (회사에 소속된 모든 담당자)
  ownerUser         User             @relation("CompanyOwner", fields: [ownerUserId], references: [id])
  buyerProfile      BuyerProfile?
  supplierProfile   SupplierProfile?
  invitations       TeamInvitation[] // 🆕 초대 코드 목록
  announcements     CompanyAnnouncement[] // 🆕 회사 공지사항
  workOrders        WorkOrder[]      // 🆕 업무지시 목록
  activityLogs      ActivityLog[]    // 🆕 활동 로그
  leaveTypes        LeaveType[]      // 🆕 휴가 유형 목록
  leaveRequests     LeaveRequest[]   // 🆕 휴가 신청 목록
}

model SupplierRegistry {
  id              String            @id @default(cuid())
  certNo          String?
  name            String
  bizNo           String            @unique
  region          String?
  representative  String?
  address         String?
  certDate        String?
  contactTel      String?
  industry        String?
  companyType     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  claimedProfiles SupplierProfile[]
}

model SupplierProfile {
  id                  String            @id @default(cuid())
  companyId           String            @unique
  region              String?
  industry            String?
  contactName         String?
  contactTel          String?
  approved            Boolean           @default(false)
  contractDescription String?
  minContractAmount   Int?
  maxContractAmount   Int?
  image1              String?
  image2              String?
  image3              String?
  image4              String?
  image5              String?
  detailPageContent   String?
  registryBizNo       String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  contractRequests    ContractRequest[]
  products            Product[]
  contracts           Contract[]        // 도급계약 목록 추가
  registry            SupplierRegistry? @relation(fields: [registryBizNo], references: [bizNo])
  company             Company           @relation(fields: [companyId], references: [id])
}

model BuyerProfile {
  id                  String                 @id @default(cuid())
  companyId           String                 @unique
  employeeCount       Int                    @default(0)
  disabledCount       Int                    @default(0)
  yearlyEmployeesJson String?
  hasLevyExemption    Boolean                @default(false)  // 🆕 부담금 면제 여부 (현재는 사용 안 함, 모두 부담금 부과)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  company             Company                @relation(fields: [companyId], references: [id])
  carts               Cart?
  contractRequests    ContractRequest[]
  disabledEmployees   DisabledEmployee[]
  calculations        Calculation[]
  contracts           Contract[]             // 도급계약 목록 추가
  monthlyData         MonthlyEmployeeData[]  // 월별 데이터 추가
}

// 월별 고용 데이터 (정밀 계산)
model MonthlyEmployeeData {
  id                    String       @id @default(cuid())
  buyerId               String
  year                  Int
  month                 Int
  
  // 입력 데이터
  totalEmployeeCount    Int          @default(0)  // 상시근로자 수 (수동 입력)
  
  // 자동 계산 데이터
  disabledCount         Int          @default(0)  // 장애인 수 (자동)
  recognizedCount       Float        @default(0)  // 인정 장애인 수 (중증 2배 포함)
  obligatedCount        Int          @default(0)  // 의무고용인원 (자동)
  shortfallCount        Int          @default(0)  // 미달 인원
  surplusCount          Float        @default(0)  // 초과 인원
  
  // 결과
  levy                  Int          @default(0)  // 부담금 (원)
  incentive             Int          @default(0)  // 장려금 (원)
  netAmount             Int          @default(0)  // 순액 (장려금 - 부담금)
  
  // 상세 내역 (JSON)
  detailJson            String?      // 직원별 상세 계산 내역
  
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  
  buyer                 BuyerProfile @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  
  @@unique([buyerId, year, month])
  @@index([buyerId, year])
}

model Product {
  id                      String          @id @default(cuid())
  supplierId              String
  title                   String
  category                String
  summary                 String?
  description             String?
  price                   Int
  unit                    String
  minOrderQty             Int             @default(1)
  leadTimeDays            Int             @default(7)
  deliveryCycle           String?
  spec                    String?
  processDescription      String?
  contractMinMonths       Int             @default(12)
  vatIncluded             Boolean         @default(true)
  shippingIncluded        Boolean         @default(false)
  extraCostNote           String?
  inspectionCriteria      String?
  defectPolicy            String?
  invoiceAvailable        Boolean         @default(true)
  quoteLeadTimeDays       Int             @default(3)
  thumbnailUrl            String?
  imageUrls               String?
  keywords                String?
  isActive                Boolean         @default(true)
  noSubcontractConfirm    Boolean         @default(false)
  monthlyDeliverySchedule String?
  monthlyBillingBasis     String?
  monthlyBillingDay       Int             @default(31)
  monthlyPaymentDay       Int             @default(10)
  monthlyFixedAmount      Int?
  monthlyAmountNote       String?
  costBreakdownJson       String?
  evidenceMethods         String?
  invoiceIssueConfirmed   Boolean         @default(false)
  receiptNote             String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  cartItems               CartItem[]
  supplier                SupplierProfile @relation(fields: [supplierId], references: [id])
}

model Cart {
  id        String       @id @default(cuid())
  buyerId   String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  buyer     BuyerProfile @relation(fields: [buyerId], references: [id])
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  qty       Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model ContractRequest {
  id                          String          @id @default(cuid())
  buyerId                     String
  supplierId                  String
  totalAmount                 Int
  status                      String          @default("REQUESTED")
  requirements                String?
  durationMonths              Int?
  buyerAcceptedRiskDisclosure Boolean         @default(false)
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
  supplier                    SupplierProfile @relation(fields: [supplierId], references: [id])
  buyer                       BuyerProfile    @relation(fields: [buyerId], references: [id])
}

model YearSetting {
  year                   Int      @id @default(autoincrement())
  privateQuotaRate       Float
  publicQuotaRate        Float
  baseLevyAmount         Int
  maxReductionRate       Float    @default(0.9)
  maxReductionByContract Float    @default(0.5)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Page {
  slug      String   @id
  title     String
  contentMd String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DisabledEmployee {
  id                     String             @id @default(cuid())
  buyerId                String
  name                   String
  phone                  String?            // 핸드폰번호 (직원 인증용)
  registrationNumber     String?            // 주민등록번호 앞 6자리 (직원 인증용 + 장려금 계산용, 예: 850315)
  disabilityType         String
  disabilityGrade        String?
  severity               String
  gender                 String
  hireDate               DateTime
  resignDate             DateTime?
  monthlySalary          Int
  hasEmploymentInsurance Boolean            @default(true)
  meetsMinimumWage       Boolean            @default(true)
  workHoursPerWeek       Int?               // 주당 근무시간 (호환성 유지)
  monthlyWorkHours       Int?               // 월 근로시간 (메인 필드)
  workType               String             @default("OFFICE") // 근무형태: OFFICE, REMOTE, HYBRID
  memo                   String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  buyer                  BuyerProfile       @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  attendanceRecords      AttendanceRecord[]

  @@index([buyerId, resignDate])
}

model Calculation {
  id         String       @id @default(cuid())
  buyerId    String
  year       Int
  month      Int?
  type       String
  resultJson String
  createdAt  DateTime     @default(now())
  buyer      BuyerProfile @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([buyerId, year, month, type])
}

// 도급계약서 (마스터)
model Contract {
  id                    String              @id @default(cuid())
  contractNo            String              @unique // 계약번호 (예: CT-2026-0001)
  buyerId               String
  supplierId            String
  contractName          String              // 계약명
  startDate             DateTime            // 계약 시작일
  endDate               DateTime            // 계약 종료일
  totalAmount           Int                 // 총 계약금액
  monthlyAmount         Int?                // 월 단위 금액 (고정인 경우)
  status                String              @default("ACTIVE") // ACTIVE, SUSPENDED, TERMINATED, COMPLETED
  paymentTerms          String?             // 결제 조건
  contractFileUrl       String?             // 계약서 파일 URL
  memo                  String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  buyer                 BuyerProfile        @relation(fields: [buyerId], references: [id])
  supplier              SupplierProfile     @relation(fields: [supplierId], references: [id])
  monthlyPerformances   MonthlyPerformance[]
  
  @@index([buyerId, status])
  @@index([supplierId, status])
  @@index([startDate, endDate])
}

// 월별 계약 이행 내역
model MonthlyPerformance {
  id                   String    @id @default(cuid())
  contractId           String
  year                 Int       // 연도 (2026)
  month                Int       // 월 (1-12)
  plannedAmount        Int       // 계획금액 (당월 예정액)
  actualAmount         Int?      // 실제금액 (실제 이행액)
  performanceRate      Float?    // 이행률 (%)
  description          String?   // 이행 내역 설명
  evidenceFileUrls     String?   // 증빙자료 URL (JSON array)
  inspectionStatus     String    @default("PENDING") // PENDING, PASSED, FAILED, WAIVED
  inspectionDate       DateTime? // 검수일
  inspectionNotes      String?   // 검수 메모
  paymentStatus        String    @default("UNPAID") // UNPAID, PARTIAL, PAID, OVERDUE
  paymentAmount        Int?      // 실제 지급액
  paymentDate          DateTime? // 지급일
  paymentMethod        String?   // 지급 방법 (계좌이체, 어음 등)
  paymentReference     String?   // 지급 참조번호
  invoiceNo            String?   // 세금계산서 번호
  invoiceDate          DateTime? // 세금계산서 발행일
  invoiceFileUrl       String?   // 세금계산서 파일 URL
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  contract             Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  @@unique([contractId, year, month])
  @@index([contractId, year, month])
  @@index([inspectionStatus, paymentStatus])
}

// 결제 이력 (상세 로그)
model PaymentHistory {
  id              String    @id @default(cuid())
  performanceId   String    // MonthlyPerformance ID
  amount          Int       // 결제 금액
  paymentDate     DateTime  // 결제일
  paymentMethod   String    // 결제 방법
  reference       String?   // 참조번호 (거래번호 등)
  status          String    @default("COMPLETED") // COMPLETED, CANCELLED, REFUNDED
  memo            String?
  createdBy       String?   // 처리자 User ID
  createdAt       DateTime  @default(now())
  
  @@index([performanceId])
  @@index([paymentDate])
}

// 출퇴근 기록
model AttendanceRecord {
  id           String           @id @default(cuid())
  companyId    String           // Company ID (바이어 회사)
  buyerId      String           // BuyerProfile ID
  employeeId   String           // DisabledEmployee ID
  userId       String           // User ID (직원 계정)
  date         String           // YYYY-MM-DD 형식
  workType     String           // OFFICE (회사 출근), REMOTE (재택 근무)
  clockIn      String?          // 출근 시간 (HH:MM:SS)
  clockOut     String?          // 퇴근 시간 (HH:MM:SS)
  workHours    Float?           // 근무 시간 (시간 단위, 소수점 2자리)
  location     String?          // GPS 좌표 또는 위치 정보 (선택)
  note         String?          // 메모
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  employee     DisabledEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@index([companyId, date])
  @@index([buyerId, date])
  @@index([userId])
  @@index([date])
}

// 회사 공지사항
model CompanyAnnouncement {
  id          String                     @id @default(cuid())
  companyId   String                     // Company ID (바이어 회사)
  buyerId     String                     // BuyerProfile ID
  title       String                     // 공지 제목
  content     String                     // 공지 내용
  priority    String                     @default("NORMAL") // URGENT, NORMAL, LOW
  isActive    Boolean                    @default(true)
  createdById String                     // 작성자 User ID
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  company     Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  readLogs    AnnouncementReadLog[]
  
  @@index([companyId, isActive])
  @@index([buyerId, isActive])
  @@index([createdAt])
}

// 공지 읽음 기록
model AnnouncementReadLog {
  id              String              @id @default(cuid())
  announcementId  String
  companyId       String              // Company ID (검색 최적화)
  buyerId         String              // BuyerProfile ID (검색 최적화)
  employeeId      String              // DisabledEmployee ID
  userId          String              // User ID (직원 계정)
  readAt          DateTime            @default(now())
  announcement    CompanyAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  
  @@unique([announcementId, employeeId])
  @@index([announcementId])
  @@index([companyId])
  @@index([buyerId])
  @@index([employeeId])
  @@index([userId])
}

// 팀원 초대 코드
model TeamInvitation {
  id              String    @id @default(cuid())
  companyId       String    // 회사 ID
  inviteCode      String    @unique // 초대 코드 (8자리 랜덤)
  invitedBy       String    // 초대한 사람 User ID
  companyType     String    // BUYER, SUPPLIER
  role            String    // 초대된 사람의 역할 (BUYER, SUPPLIER)
  inviteeName     String?   // 초대받을 사람 이름
  inviteePhone    String?   // 초대받을 사람 핸드폰
  expiresAt       DateTime  // 만료일 (생성 후 7일)
  isUsed          Boolean   @default(false) // 사용 여부
  usedBy          String?   // 사용한 사람 User ID
  usedAt          DateTime? // 사용 시각
  createdAt       DateTime  @default(now())
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sender          User      @relation("InvitationSender", fields: [invitedBy], references: [id])
  
  @@index([inviteCode])
  @@index([companyId])
  @@index([expiresAt, isUsed])
}

// 🆕 활동 로그 (팀원들의 모든 활동 기록)
model ActivityLog {
  id          String   @id @default(cuid())
  companyId   String   // 회사 ID
  userId      String   // 행동한 사람 User ID
  userName    String   // 행동한 사람 이름 (스냅샷)
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, INVITE, etc.
  targetType  String   // EMPLOYEE, ANNOUNCEMENT, TEAM_MEMBER, COMPANY, MONTHLY_DATA, etc.
  targetId    String?  // 대상 ID (optional)
  targetName  String?  // 대상 이름 (스냅샷)
  details     String?  // 추가 정보 (JSON)
  ipAddress   String?  // IP 주소
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
  @@index([targetType, targetId])
}

// 견적 문의 (장표사닷컴으로 전달)
model QuoteInquiry {
  id                String   @id @default(cuid())
  productId         String?  // 관련 상품 ID (선택)
  companyName       String   // 회사명
  contactName       String   // 담당자명
  contactPhone      String   // 연락처
  contactEmail      String?  // 이메일
  bizNo             String?  // 사업자등록번호
  category          String   // 상품 카테고리
  productName       String   // 상품명
  quantity          Int?     // 수량
  budget            String?  // 예산 범위
  timeline          String?  // 납기 희망일
  requirements      String?  // 상세 요구사항
  attachmentUrls    String?  // 첨부파일 URL (JSON array)
  status            String   @default("PENDING") // PENDING, IN_PROGRESS, QUOTED, COMPLETED, CANCELLED
  adminNote         String?  // 관리자 메모
  respondedAt       DateTime? // 응답일시
  respondedBy       String?  // 응답자 User ID
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([status, createdAt])
  @@index([category])
  @@index([contactPhone])
}

// 업무지시 (단체 또는 개인 발송, 음성 첨부 가능)
model WorkOrder {
  id              String                @id @default(cuid())
  companyId       String                // Company ID (바이어 회사)
  buyerId         String                // BuyerProfile ID
  title           String                // 지시 제목
  content         String                // 지시 내용 (description으로 변경 추천)
  description     String?               // 🆕 상세 설명 (content와 동일하게 사용 가능)
  targetType      String                // 대상 타입: ALL (전체), GROUP (그룹), INDIVIDUAL (개인)
  targetEmployees String?               // JSON array: 대상 직원 ID 목록 (targetType이 GROUP 또는 INDIVIDUAL일 때)
  priority        String                @default("NORMAL") // URGENT, HIGH, NORMAL, LOW
  status          String                @default("PENDING") // 🆕 PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  dueDate         DateTime?             // 완료 기한
  attachmentUrls  String?               // 🆕 첨부파일 URL (JSON array)
  audioFileUrl    String?               // 음성 파일 URL (선택)
  audioFileName   String?               // 음성 파일 이름
  audioDuration   Int?                  // 음성 파일 길이 (초)
  isActive        Boolean               @default(true)
  createdById     String                // 작성자 User ID
  createdByName   String                // 작성자 이름 (스냅샷)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  company         Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recipients      WorkOrderRecipient[]  // 🆕 수신자 목록 (상태 관리)
  
  @@index([companyId, isActive])
  @@index([buyerId, isActive])
  @@index([createdAt])
  @@index([priority, dueDate])
  @@index([status])
}

// 🆕 업무지시 수신자 (개별 상태 관리)
model WorkOrderRecipient {
  id                String      @id @default(cuid())
  workOrderId       String
  companyId         String      // Company ID (검색 최적화)
  buyerId           String      // BuyerProfile ID (검색 최적화)
  employeeId        String      // DisabledEmployee ID
  userId            String      // User ID (직원 계정)
  status            String      @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, REJECTED
  startedAt         DateTime?   // 시작 시간
  completedAt       DateTime?   // 완료 시간
  completionReport  String?     // 완료 보고서
  rejectionReason   String?     // 거부 사유
  adminApproval     String      @default("PENDING") // 🆕 PENDING, APPROVED, REJECTED (관리자 승인)
  adminNote         String?     // 🆕 관리자 메모
  approvedAt        DateTime?   // 🆕 승인 시간
  approvedBy        String?     // 🆕 승인한 관리자 User ID
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  workOrder         WorkOrder   @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  @@unique([workOrderId, employeeId])
  @@index([workOrderId])
  @@index([companyId])
  @@index([buyerId])
  @@index([employeeId])
  @@index([userId])
  @@index([status])
  @@index([adminApproval])
}

// 업무지시 확인 기록 (레거시 - 이제 WorkOrderRecipient로 대체)
model WorkOrderConfirmation {
  id              String      @id @default(cuid())
  workOrderId     String
  companyId       String      // Company ID (검색 최적화)
  buyerId         String      // BuyerProfile ID (검색 최적화)
  employeeId      String      // DisabledEmployee ID
  userId          String      // User ID (직원 계정)
  confirmedAt     DateTime    @default(now())
  note            String?     // 확인 메모 (선택)
  
  @@unique([workOrderId, employeeId])
  @@index([workOrderId])
  @@index([companyId])
  @@index([buyerId])
  @@index([employeeId])
  @@index([userId])
}

// 실시간 알림
model Notification {
  id          String    @id @default(cuid())
  userId      String    // 수신자 User ID
  type        String    // LEAVE_REQUEST, LEAVE_APPROVED, LEAVE_REJECTED, LEAVE_EXPIRING, WORK_ORDER, ANNOUNCEMENT, ATTENDANCE, SYSTEM
  title       String    // 알림 제목
  message     String    // 알림 내용
  link        String?   // 관련 링크 (선택)
  data        String?   // 추가 데이터 (JSON)
  read        Boolean   @default(false)
  readAt      DateTime? // 읽은 시각
  priority    String    @default("NORMAL") // URGENT, NORMAL, LOW
  category    String    @default("GENERAL") // LEAVE, WORK, SALARY, SYSTEM, GENERAL
  createdAt   DateTime  @default(now())
  
  user        User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@index([type])
  @@index([category])
  @@index([priority])
}

// 🆕 휴가 유형 (회사별 관리)
model LeaveType {
  id                     String         @id @default(cuid())
  companyId              String         // 회사 ID
  name                   String         // 휴가 유형명 (예: 연차, 병가, 경조사)
  description            String?        // 설명
  requiresDocument       Boolean        @default(false) // 증빙서류 필요 여부
  maxDaysPerYear         Int?           // 연간 최대 사용일수
  isPaid                 Boolean        @default(true)  // 유급 여부
  isActive               Boolean        @default(true)  // 활성 상태
  displayOrder           Int            @default(0)     // 표시 순서
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  company                Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leaveRequests          LeaveRequest[]
  
  @@unique([companyId, name])
  @@index([companyId, isActive])
}

// 🆕 휴가 신청
model LeaveRequest {
  id                String       @id @default(cuid())
  companyId         String       // 회사 ID
  buyerId           String       // BuyerProfile ID
  leaveTypeId       String       // 휴가 유형 ID
  employeeId        String       // DisabledEmployee ID
  userId            String       // User ID (직원 계정)
  startDate         DateTime     // 시작일
  endDate           DateTime     // 종료일
  days              Float        // 일수 (0.5일 단위 가능)
  reason            String?      // 사유
  status            String       @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  documentSent      Boolean      @default(false) // 증빙서류 전송 여부
  documentNote      String?      // 서류 관련 메모
  reviewedBy        String?      // 검토자 User ID
  reviewedAt        DateTime?    // 검토 시각
  reviewNote        String?      // 검토 메모
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  company           Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leaveType         LeaveType    @relation(fields: [leaveTypeId], references: [id])
  
  @@index([companyId, status])
  @@index([buyerId, status])
  @@index([employeeId, status])
  @@index([userId])
  @@index([startDate, endDate])
}

// 🆕 연차(휴가) 잔여 현황
model AnnualLeaveBalance {
  id                  String    @id @default(cuid())
  companyId           String    // 회사 ID
  buyerId             String    // BuyerProfile ID
  employeeId          String    @unique // DisabledEmployee ID
  userId              String?   // User ID (직원 계정, 있으면)
  
  // 근속 정보
  hireDate            DateTime  // 입사일
  workYears           Int       // 근속연수
  workMonths          Int       // 총 근속개월수
  
  // 연차 발생
  year                Int       // 귀속 연도 (예: 2026)
  totalGenerated      Float     // 총 발생 연차
  baseLeave           Float     // 기본 연차 (15일 or 개근일수)
  bonusLeave          Float     // 가산 연차 (2년마다 1일)
  
  // 연차 사용 및 잔여
  used                Float     @default(0) // 사용한 연차
  remaining           Float     // 남은 연차 (= totalGenerated - used)
  
  // 추가 정보
  isUnderOneYear      Boolean   // 1년 미만 여부
  expiryDate          DateTime  // 연차 소멸일 (발생일로부터 1년 후)
  
  // 연차 촉진 알림
  firstNoticeDate     DateTime  // 1차 촉진 알림일 (소멸 6개월 전)
  secondNoticeDate    DateTime  // 2차 촉진 알림일 (소멸 2개월 전)
  firstNoticeSent     Boolean   @default(false) // 1차 알림 발송 여부
  secondNoticeSent    Boolean   @default(false) // 2차 알림 발송 여부
  
  // 퇴사 시 정산
  dailyWage           Float?    // 1일 통상임금 (퇴사 시 계산용)
  unusedPayment       Float?    // 미사용 연차 수당 (퇴사 시)
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  @@index([companyId, year])
  @@index([buyerId, year])
  @@index([employeeId, year])
  @@index([expiryDate])
  @@index([firstNoticeDate])
  @@index([secondNoticeDate])
}
