# Production Environment Variables
# Copy this file to .env.production and fill in actual values

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/jangpyosa?schema=public"

# JWT Secrets
JWT_SECRET="your_jwt_secret_here"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_here"

# API Configuration
PORT=4000
CORS_ORIGIN="https://jangpyosa.com"

# APICK Integration (Real Mode)
APICK_PROVIDER="real"
APICK_API_KEY="YOUR_ACTUAL_APICK_API_KEY_HERE"

# Web Application
NEXT_PUBLIC_API_BASE="https://jangpyosa.com:4000"
